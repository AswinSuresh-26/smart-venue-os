# Backend Environment Configuration Template
# Copy this file to .env and fill in your Google Cloud credentials

# ============================================
# Google Cloud Project Configuration
# ============================================
GCP_PROJECT_ID=diesel-command-493401-q7

# ============================================
# Google Gemini API (AI Assistant)
# ============================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Google Cloud Pub/Sub (Real-time Streaming)
# ============================================
# Topic name to publish crowd data to
# Create with: gcloud pubsub topics create crowd-data
PUBSUB_CROWD_TOPIC=crowd-data

# ============================================
# Google Cloud BigQuery (Analytics)
# ============================================
# Dataset for storing crowd analytics
# Create with: bq mk --dataset svos_analytics
BIGQUERY_DATASET=svos_analytics

# Table name for crowd events
# Auto-created by backend on startup
BIGQUERY_TABLE=crowd_events

# ============================================
# Google Cloud Authentication
# ============================================
# Path to service account JSON key
# Download from: Cloud Console > Service Accounts > Keys
# Set via environment variable:
#   export GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# This is optional - uses default credentials if not set

# ============================================
# CORS Configuration (Development)
# ============================================
# Allowed origins for API requests
# For production, restrict to your domain
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# FastAPI Configuration
# ============================================
# Server host and port
HOST=0.0.0.0
PORT=8000

# Environment: development, staging, production
ENVIRONMENT=development
